# =============================================================================
# AI FUNNEL PLATFORM - GIT IGNORE RULES
# =============================================================================
# Comprehensive .gitignore for React + Vite + Node.js project
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLES & SECRETS
# -----------------------------------------------------------------------------
# Never commit sensitive data
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.staging

# Backup environment files
*.env.backup
*.env.bak

# Secret keys and credentials
secrets/
*.pem
*.key
*.cert
*.p12
*.pfx

# -----------------------------------------------------------------------------
# NODE MODULES & DEPENDENCIES
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency directories
jspm_packages/
bower_components/

# Package manager lock files (optional - uncomment if you want to ignore)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# BUILD OUTPUT & DISTRIBUTION
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
*.local

# Vite build cache
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Production bundles
bundle/
public/build/

# Static assets cache
.cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# LOGS & DEBUG FILES
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime logs
*.log.*
combined.log
error.log
access.log

# Debug output
debug/
.pnp.*

# -----------------------------------------------------------------------------
# OPERATING SYSTEM FILES
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# IDE & EDITOR FILES
# -----------------------------------------------------------------------------
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags
[._]*.un~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Atom
.atom/

# Eclipse
.project
.classpath
.settings/
.loadpath
.recommenders

# NetBeans
nbproject/private/
build/
nbbuild/
nbdist/
.nb-gradle/

# -----------------------------------------------------------------------------
# TEST COVERAGE & TESTING
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
lib-cov/

# Jest
jest-results/
.jest-cache/

# Cypress
cypress/videos/
cypress/screenshots/
cypress/results/
cypress/downloads/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# TEMPORARY FILES & CACHES
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*.bak
*.cache
*.pid
*.seed
*.pid.lock

# npm cache
.npm/
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Yarn cache
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Parcel cache
.parcel-cache/

# Next.js cache
.next/
next-env.d.ts

# Nuxt.js cache
.nuxt/

# Gatsby cache
.cache/
public/

# -----------------------------------------------------------------------------
# MISC RUNTIME FILES
# -----------------------------------------------------------------------------
# Optional npm/yarn cache directory
.npm
.yarn-integrity

# dotenv environment variable files
.env.backup

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------------------------------------------
# UPLOADED FILES & MEDIA
# -----------------------------------------------------------------------------
# User uploads (if stored locally)
uploads/
public/uploads/
src/assets/uploads/

# Generated files
generated/
public/generated/

# Temporary downloads
downloads/
tmp/
temp/

# -----------------------------------------------------------------------------
# DATABASE FILES (if using local DB)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# -----------------------------------------------------------------------------
# DOCUMENTATION BUILD OUTPUT
# -----------------------------------------------------------------------------
docs/_build/
docs/.vuepress/dist
.docusaurus/

# Storybook
storybook-static/
.storybook-out/

# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING
# -----------------------------------------------------------------------------
# Lighthouse reports
lighthouse/
*.lighthouse.html

# Bundle analysis
stats.html
bundle-stats.json
.webpack-bundle-analyzer/

# Performance logs
.performance/

# -----------------------------------------------------------------------------
# CUSTOM PROJECT FILES
# -----------------------------------------------------------------------------
# Local configuration overrides
config.local.js
config.local.json

# Local scripts
scripts/local/

# Mock data (if you want to exclude)
# src/mocks/local/

# Test fixtures (optional)
# fixtures/local/

# Development notes
NOTES.md
TODO.local.md
SCRATCH.md

# Backup files
*.backup
*.bck
*.old

# Archive files
*.zip
*.tar
*.gz
*.rar
*.7z
archive/

# -----------------------------------------------------------------------------
# THIRD-PARTY SERVICE FILES
# -----------------------------------------------------------------------------
# Vercel
.vercel

# Netlify
.netlify

# Firebase
.firebase/
.firebaserc
firebase-debug.log
firestore-debug.log
pubsub-debug.log
ui-debug.log

# Sentry
.sentryclirc

# Terraform
*.tfstate
*.tfstate.backup
.terraform/

# Docker
docker-compose.override.yml

# Kubernetes
*.kubeconfig

# -----------------------------------------------------------------------------
# SECURITY & AUDIT
# -----------------------------------------------------------------------------
# Security audit logs
audit/
security-report/

# Dependency vulnerabilities
.snyk

# -----------------------------------------------------------------------------
# AI & ML FILES (if applicable)
# -----------------------------------------------------------------------------
# Model files
*.h5
*.pkl
*.pth
*.onnx
models/

# Training data
data/raw/
data/processed/

# -----------------------------------------------------------------------------
# MISCELLANEOUS
# -----------------------------------------------------------------------------
# Sitemap (auto-generated)
public/sitemap.xml
public/robots.txt

# Service worker (auto-generated)
public/sw.js
public/workbox-*.js

# Source maps in production (optional - uncomment to exclude)
# *.map

# Lock files for specific package managers (choose one to track)
# Uncomment the ones you DON'T want to track:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# =============================================================================
# END OF GITIGNORE
# =============================================================================
# Remember to:
# 1. Review this file based on your specific needs
# 2. Uncomment sections that apply to your project
# 3. Add project-specific exclusions as needed
# 4. Keep this file updated as project evolves
