# =============================================================================
# AI FUNNEL PLATFORM - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION ENVIRONMENT
# -----------------------------------------------------------------------------
# Environment: development | staging | production
NODE_ENV=development

# App Information
VITE_APP_NAME="AI Funnel Platform"
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# -----------------------------------------------------------------------------
# Backend API Base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# API Retry Configuration
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000

# WebSocket URL (for real-time features)
VITE_WS_URL=ws://localhost:8000/ws

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# JWT Token Configuration
VITE_ACCESS_TOKEN_KEY=ai_funnel_access_token
VITE_REFRESH_TOKEN_KEY=ai_funnel_refresh_token
VITE_TOKEN_EXPIRY_BUFFER=300000

# Session timeout (milliseconds) - 30 minutes
VITE_SESSION_TIMEOUT=1800000

# OAuth Provider Client IDs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id
VITE_FACEBOOK_CLIENT_ID=your-facebook-app-id

# OAuth Redirect URIs
VITE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------
# OpenAI Configuration
VITE_OPENAI_API_KEY=sk-your-openai-api-key
VITE_OPENAI_MODEL=gpt-4-turbo-preview
VITE_OPENAI_MAX_TOKENS=2000

# Alternative AI Providers (if using)
VITE_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
VITE_COHERE_API_KEY=your-cohere-api-key

# AI Features Toggle
VITE_ENABLE_AI_GENERATION=true
VITE_ENABLE_AI_OPTIMIZATION=true
VITE_AI_CREDITS_DEFAULT=100

# -----------------------------------------------------------------------------
# MEDIA & FILE UPLOAD
# -----------------------------------------------------------------------------
# Upload Service Provider: local | s3 | cloudinary
VITE_UPLOAD_PROVIDER=cloudinary

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_API_KEY=your-cloudinary-api-key
VITE_CLOUDINARY_UPLOAD_PRESET=ai_funnel_uploads

# AWS S3 Configuration (if using S3)
VITE_AWS_REGION=us-east-1
VITE_AWS_BUCKET=ai-funnel-platform-uploads
VITE_AWS_ACCESS_KEY_ID=your-aws-access-key
VITE_AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# File Upload Limits
VITE_MAX_FILE_SIZE=10485760
VITE_MAX_IMAGE_SIZE=5242880
VITE_MAX_VIDEO_SIZE=52428800
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
VITE_ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime

# -----------------------------------------------------------------------------
# ANALYTICS & TRACKING
# -----------------------------------------------------------------------------
# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager
VITE_GTM_ID=GTM-XXXXXXX

# Mixpanel
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Hotjar
VITE_HOTJAR_ID=your-hotjar-id
VITE_HOTJAR_SNIPPET_VERSION=6

# Sentry Error Tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog (Product Analytics)
VITE_POSTHOG_API_KEY=phc_your-posthog-key
VITE_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# THIRD-PARTY INTEGRATIONS
# -----------------------------------------------------------------------------
# Email Service (SendGrid, Mailgun, etc.)
VITE_EMAIL_SERVICE=sendgrid
VITE_SENDGRID_API_KEY=SG.your-sendgrid-api-key

# SMS Service (Twilio)
VITE_TWILIO_ACCOUNT_SID=your-twilio-account-sid
VITE_TWILIO_AUTH_TOKEN=your-twilio-auth-token
VITE_TWILIO_PHONE_NUMBER=+1234567890

# Payment Processing (Stripe)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# QR Code Generation
VITE_QR_CODE_SERVICE=https://api.qrserver.com/v1/create-qr-code/

# URL Shortener (Bitly)
VITE_BITLY_ACCESS_TOKEN=your-bitly-access-token

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Feature Toggles
VITE_ENABLE_VISUAL_FLOW_BUILDER=true
VITE_ENABLE_AI_WIZARD=true
VITE_ENABLE_ANALYTICS_DASHBOARD=true
VITE_ENABLE_MULTI_LANGUAGE=false
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_A_B_TESTING=true
VITE_ENABLE_CUSTOM_DOMAIN=false
VITE_ENABLE_WHITE_LABEL=false
VITE_ENABLE_API_ACCESS=false

# Beta Features
VITE_ENABLE_BETA_FEATURES=false
VITE_BETA_ACCESS_CODE=beta2024

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# Rate Limiting (client-side)
VITE_API_RATE_LIMIT=100
VITE_API_RATE_WINDOW=60000

# Cache Configuration
VITE_ENABLE_CACHE=true
VITE_CACHE_DURATION=300000

# Debounce Delays (milliseconds)
VITE_SEARCH_DEBOUNCE=500
VITE_AUTO_SAVE_DEBOUNCE=2000

# Date & Time
VITE_DEFAULT_TIMEZONE=America/New_York
VITE_DATE_FORMAT=MM/DD/YYYY
VITE_TIME_FORMAT=hh:mm A

# Localization
VITE_DEFAULT_LOCALE=en-US
VITE_SUPPORTED_LOCALES=en-US,es-ES,fr-FR,de-DE

# -----------------------------------------------------------------------------
# PUBLIC FUNNEL SETTINGS
# -----------------------------------------------------------------------------
# Public Funnel Domain
VITE_PUBLIC_FUNNEL_DOMAIN=https://funnels.yourdomain.com

# Public Funnel URL Pattern
VITE_FUNNEL_URL_PATTERN=/f/

# Tracking & Cookies
VITE_ENABLE_TRACKING=true
VITE_COOKIE_CONSENT_REQUIRED=true
VITE_COOKIE_DOMAIN=.yourdomain.com

# -----------------------------------------------------------------------------
# DEVELOPMENT & DEBUGGING
# -----------------------------------------------------------------------------
# Debug Mode
VITE_DEBUG_MODE=true
VITE_ENABLE_REDUX_DEVTOOLS=true
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true

# Logging
VITE_LOG_LEVEL=debug
VITE_ENABLE_CONSOLE_LOGS=true
VITE_ENABLE_NETWORK_LOGS=true

# Mock Data (for development)
VITE_USE_MOCK_API=false
VITE_MOCK_API_DELAY=1000

# Hot Module Replacement
VITE_HMR_PORT=3000

# Source Maps
VITE_ENABLE_SOURCE_MAPS=true

# -----------------------------------------------------------------------------
# PERFORMANCE & OPTIMIZATION
# -----------------------------------------------------------------------------
# Bundle Analysis
VITE_ANALYZE_BUNDLE=false

# Code Splitting
VITE_ENABLE_CODE_SPLITTING=true

# Lazy Loading
VITE_ENABLE_LAZY_LOADING=true

# Image Optimization
VITE_ENABLE_IMAGE_OPTIMIZATION=true
VITE_IMAGE_QUALITY=80

# Compression
VITE_ENABLE_GZIP=true
VITE_ENABLE_BROTLI=true

# -----------------------------------------------------------------------------
# SECURITY HEADERS & POLICIES
# -----------------------------------------------------------------------------
# Content Security Policy
VITE_CSP_ENABLED=true

# CORS Origins (comma-separated)
VITE_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Trusted Domains (for iframe embedding)
VITE_TRUSTED_DOMAINS=yourdomain.com,*.yourdomain.com

# -----------------------------------------------------------------------------
# NOTIFICATIONS
# -----------------------------------------------------------------------------
# Browser Notifications
VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Toast Notification Settings
VITE_TOAST_DURATION=5000
VITE_TOAST_POSITION=top-right

# -----------------------------------------------------------------------------
# LEGAL & COMPLIANCE
# -----------------------------------------------------------------------------
# Privacy & Terms URLs
VITE_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
VITE_TERMS_OF_SERVICE_URL=https://yourdomain.com/terms
VITE_COOKIE_POLICY_URL=https://yourdomain.com/cookies

# GDPR Compliance
VITE_GDPR_ENABLED=true
VITE_DATA_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# SOCIAL MEDIA
# -----------------------------------------------------------------------------
# Social Sharing
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_TWITTER_HANDLE=@yourhandle

# Open Graph Defaults
VITE_OG_IMAGE=https://yourdomain.com/og-image.jpg
VITE_OG_DESCRIPTION=AI-Powered Funnel Builder Platform

# -----------------------------------------------------------------------------
# SUPPORT & HELP
# -----------------------------------------------------------------------------
# Help & Documentation
VITE_HELP_CENTER_URL=https://help.yourdomain.com
VITE_DOCUMENTATION_URL=https://docs.yourdomain.com
VITE_SUPPORT_EMAIL=support@yourdomain.com

# Intercom / Live Chat
VITE_INTERCOM_APP_ID=your-intercom-app-id
VITE_ENABLE_LIVE_CHAT=false

# -----------------------------------------------------------------------------
# CUSTOM BRANDING (White Label Support)
# -----------------------------------------------------------------------------
# Brand Colors (hex codes)
VITE_BRAND_PRIMARY_COLOR=#6366f1
VITE_BRAND_SECONDARY_COLOR=#8b5cf6
VITE_BRAND_ACCENT_COLOR=#ec4899

# Brand Assets
VITE_BRAND_LOGO_URL=/assets/logo.svg
VITE_BRAND_FAVICON_URL=/assets/favicon.ico

# Custom Domain Support
VITE_CUSTOM_DOMAIN_ENABLED=false

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
# Remember to:
# 1. Copy this file to .env.local
# 2. Update all placeholder values with your actual credentials
# 3. Never commit .env.local to version control
# 4. Rotate sensitive keys regularly
# 5. Use different values for development/staging/production
# =============================================================================
