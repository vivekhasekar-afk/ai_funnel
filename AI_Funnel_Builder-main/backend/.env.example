# =============================================================================
# AI FUNNEL BUILDER - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=AI Funnel Builder
APP_ENV=development  # development | staging | production
DEBUG=True  # Set to False in production
API_VERSION=v1
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173  # Comma-separated

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4  # Number of uvicorn workers (production: CPU cores * 2 + 1)
RELOAD=True  # Auto-reload on code changes (development only)

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/funnel_platform
DATABASE_POOL_SIZE=20  # Connection pool size
DATABASE_MAX_OVERFLOW=10  # Max connections beyond pool_size
DATABASE_ECHO=False  # Log all SQL queries (development only)

# Test Database (for pytest)
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/funnel_platform_test

# -----------------------------------------------------------------------------
# REDIS (Caching & Celery Broker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=0  # Database index for caching
REDIS_CELERY_DB=1  # Database index for Celery broker
REDIS_MAX_CONNECTIONS=50

# -----------------------------------------------------------------------------
# MONGODB (Flexible Data & AI Training)
# -----------------------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=funnel_platform
MONGODB_MAX_POOL_SIZE=100

# -----------------------------------------------------------------------------
# OPENAI (AI Generation - CRITICAL)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview  # gpt-4-turbo-preview | gpt-4 | gpt-3.5-turbo
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7  # Creativity level (0.0-1.0)
OPENAI_TIMEOUT=30  # Seconds
OPENAI_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# EMAIL (SendGrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@funnelbuilder.ai
SENDGRID_FROM_NAME=AI Funnel Builder
SENDGRID_WELCOME_TEMPLATE_ID=d-xxxxx
SENDGRID_LEAD_NOTIFICATION_TEMPLATE_ID=d-xxxxx

# -----------------------------------------------------------------------------
# STRIPE (Payments & Subscriptions)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_CREATOR_PRO=price_xxxxx  # Monthly price ID
STRIPE_PRICE_BRAND_STARTER=price_xxxxx

# -----------------------------------------------------------------------------
# AWS S3 (File Storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=funnel-builder-uploads
AWS_S3_REGION=us-east-1
AWS_S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com

# -----------------------------------------------------------------------------
# META/FACEBOOK (Ads & Pixel)
# -----------------------------------------------------------------------------
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-long-lived-access-token
META_PIXEL_ID=your-pixel-id

# -----------------------------------------------------------------------------
# GOOGLE (Analytics & Ads)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_ADS_DEVELOPER_TOKEN=your-dev-token

# -----------------------------------------------------------------------------
# SENTRY (Error Tracking - Production)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of requests

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AI_GENERATION=5/minute  # Expensive operation
RATE_LIMIT_RESPONSE_SUBMIT=100/minute

# -----------------------------------------------------------------------------
# CELERY (Background Tasks)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True

# -----------------------------------------------------------------------------
# ML/AI MODELS
# -----------------------------------------------------------------------------
ML_MODELS_PATH=./ml_models
ML_COMPLETION_MODEL_VERSION=v1
ML_LEAD_SCORING_MODEL_VERSION=v1
ML_RETRAIN_SCHEDULE=weekly  # Cron: 0 0 * * 0

# -----------------------------------------------------------------------------
# DATA PIPELINE
# -----------------------------------------------------------------------------
DATA_WAREHOUSE_ENABLED=False  # Enable for production
DATA_WAREHOUSE_TYPE=bigquery  # bigquery | snowflake | redshift
BIGQUERY_PROJECT_ID=your-project-id
BIGQUERY_DATASET_ID=funnel_analytics
BIGQUERY_CREDENTIALS_PATH=./credentials/bigquery-key.json

# -----------------------------------------------------------------------------
# MONITORING & LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json  # json | text
LOG_FILE_PATH=./logs/app.log
LOG_ROTATION=10 MB  # Rotate when file reaches 10MB
LOG_RETENTION=30 days

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_TEMPLATE_MARKETPLACE=False  # Enable marketplace (Phase 2)
FEATURE_BRAND_PORTAL=False  # Enable brand features (Phase 2)
FEATURE_AB_TESTING=False  # Enable A/B testing (Phase 3)
FEATURE_WEBHOOKS=False  # Enable custom webhooks (Phase 2)

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CORS_ALLOW_CREDENTIALS=True
SECURE_SSL_REDIRECT=False  # Set True in production with HTTPS
SESSION_COOKIE_SECURE=False  # Set True in production
CSRF_COOKIE_SECURE=False  # Set True in production

# -----------------------------------------------------------------------------
# ANALYTICS & TRACKING
# -----------------------------------------------------------------------------
ENABLE_ANALYTICS_TRACKING=True
ANALYTICS_BATCH_SIZE=100  # Events batched before DB insert
ANALYTICS_FLUSH_INTERVAL=5  # Seconds

# -----------------------------------------------------------------------------
# QUOTAS & LIMITS (by Subscription Tier)
# -----------------------------------------------------------------------------
QUOTA_FREE_FUNNELS=3
QUOTA_FREE_RESPONSES_PER_MONTH=100
QUOTA_FREE_LEADS_EXPORT=50

QUOTA_PRO_FUNNELS=50
QUOTA_PRO_RESPONSES_PER_MONTH=10000
QUOTA_PRO_LEADS_EXPORT=unlimited

# -----------------------------------------------------------------------------
# CACHE TTL (Time To Live in seconds)
# -----------------------------------------------------------------------------
CACHE_TTL_BENCHMARKS=86400  # 24 hours
CACHE_TTL_ANALYTICS=3600  # 1 hour
CACHE_TTL_TEMPLATES=7200  # 2 hours
CACHE_TTL_USER_SESSION=1800  # 30 minutes

# -----------------------------------------------------------------------------
# EXTERNAL INTEGRATIONS (Optional)
# -----------------------------------------------------------------------------
# CRM
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_API_KEY=

# Email Marketing
MAILCHIMP_API_KEY=
KLAVIYO_API_KEY=

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
